{
  "name": "muted-boilerplate-vscode",
  "displayName": "Muted Boilerplate",
  "description": "Visually mute boilerplate (telemetry, logging, signatures, guards) so the interesting code stays prominent.",
  "version": "0.1.0",
  "publisher": "GerhardVanZyl",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:csharp",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "mutedBoilerplate.toggleTelemetry",
        "title": "Muted Boilerplate: Toggle Telemetry"
      },
      {
        "command": "mutedBoilerplate.toggleLogging",
        "title": "Muted Boilerplate: Toggle Logging"
      },
      {
        "command": "mutedBoilerplate.toggleSignature",
        "title": "Muted Boilerplate: Toggle Signature"
      },
      {
        "command": "mutedBoilerplate.toggleGuards",
        "title": "Muted Boilerplate: Toggle Guards"
      },
      {
        "command": "mutedBoilerplate.toggleAll",
        "title": "Muted Boilerplate: Toggle All"
      },
      {
        "command": "mutedBoilerplate.toggleExclusions",
        "title": "Muted Boilerplate: Toggle Exclusions"
      },
      {
        "command": "mutedBoilerplate.toggleUser1",
        "title": "Muted Boilerplate: Toggle User Slot 1"
      },
      {
        "command": "mutedBoilerplate.toggleUser2",
        "title": "Muted Boilerplate: Toggle User Slot 2"
      },
      {
        "command": "mutedBoilerplate.toggleUser3",
        "title": "Muted Boilerplate: Toggle User Slot 3"
      },
      {
        "command": "mutedBoilerplate.toggleUser4",
        "title": "Muted Boilerplate: Toggle User Slot 4"
      },
      {
        "command": "mutedBoilerplate.toggleUser5",
        "title": "Muted Boilerplate: Toggle User Slot 5"
      },
      {
        "command": "mutedBoilerplate.toggleUser6",
        "title": "Muted Boilerplate: Toggle User Slot 6"
      },
      {
        "command": "mutedBoilerplate.toggleUser7",
        "title": "Muted Boilerplate: Toggle User Slot 7"
      },
      {
        "command": "mutedBoilerplate.toggleUser8",
        "title": "Muted Boilerplate: Toggle User Slot 8"
      },
      {
        "command": "mutedBoilerplate.reloadRules",
        "title": "Muted Boilerplate: Reload Rules"
      }
    ],
    "keybindings": [
      {
        "command": "mutedBoilerplate.toggleTelemetry",
        "key": "ctrl+alt+m t",
        "mac": "cmd+alt+m t",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleLogging",
        "key": "ctrl+alt+m l",
        "mac": "cmd+alt+m l",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleSignature",
        "key": "ctrl+alt+m s",
        "mac": "cmd+alt+m s",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleGuards",
        "key": "ctrl+alt+m g",
        "mac": "cmd+alt+m g",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleAll",
        "key": "ctrl+alt+m a",
        "mac": "cmd+alt+m a",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleExclusions",
        "key": "ctrl+alt+m x",
        "mac": "cmd+alt+m x",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser1",
        "key": "ctrl+alt+m 1",
        "mac": "cmd+alt+m 1",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser2",
        "key": "ctrl+alt+m 2",
        "mac": "cmd+alt+m 2",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser3",
        "key": "ctrl+alt+m 3",
        "mac": "cmd+alt+m 3",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser4",
        "key": "ctrl+alt+m 4",
        "mac": "cmd+alt+m 4",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser5",
        "key": "ctrl+alt+m 5",
        "mac": "cmd+alt+m 5",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser6",
        "key": "ctrl+alt+m 6",
        "mac": "cmd+alt+m 6",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser7",
        "key": "ctrl+alt+m 7",
        "mac": "cmd+alt+m 7",
        "when": "editorTextFocus"
      },
      {
        "command": "mutedBoilerplate.toggleUser8",
        "key": "ctrl+alt+m 8",
        "mac": "cmd+alt+m 8",
        "when": "editorTextFocus"
      }
    ],
    "colors": [
      {
        "id": "mutedBoilerplate.telemetry.foreground",
        "description": "Foreground for muted telemetry calls.",
        "defaults": {
          "dark": "#7A7A7A",
          "light": "#9A9A9A",
          "highContrast": "#A0A0A0",
          "highContrastLight": "#606060"
        }
      },
      {
        "id": "mutedBoilerplate.logging.foreground",
        "description": "Foreground for muted logging calls.",
        "defaults": {
          "dark": "#888888",
          "light": "#A0A0A0",
          "highContrast": "#A8A8A8",
          "highContrastLight": "#666666"
        }
      },
      {
        "id": "mutedBoilerplate.signature.foreground",
        "description": "Foreground for muted method signatures.",
        "defaults": {
          "dark": "#9A9A9A",
          "light": "#888888",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#555555"
        }
      },
      {
        "id": "mutedBoilerplate.guards.foreground",
        "description": "Foreground for muted parameter guards.",
        "defaults": {
          "dark": "#C2C9BE",
          "light": "#5A6358",
          "highContrast": "#D4DCD2",
          "highContrastLight": "#3A4239"
        }
      },
      {
        "id": "mutedBoilerplate.user1.foreground",
        "description": "Foreground for muted user slot 1.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user2.foreground",
        "description": "Foreground for muted user slot 2.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user3.foreground",
        "description": "Foreground for muted user slot 3.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user4.foreground",
        "description": "Foreground for muted user slot 4.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user5.foreground",
        "description": "Foreground for muted user slot 5.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user6.foreground",
        "description": "Foreground for muted user slot 6.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user7.foreground",
        "description": "Foreground for muted user slot 7.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      },
      {
        "id": "mutedBoilerplate.user8.foreground",
        "description": "Foreground for muted user slot 8.",
        "defaults": {
          "dark": "#8A8A8A",
          "light": "#9A9A9A",
          "highContrast": "#B0B0B0",
          "highContrastLight": "#5A5A5A"
        }
      }
    ],
    "configuration": {
      "title": "Muted Boilerplate",
      "properties": {
        "mutedBoilerplate.rulesPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a custom rules JSON file. Empty = use the embedded defaults."
        },
        "mutedBoilerplate.exclusionsEnabled": {
          "type": "boolean",
          "default": true,
          "description": "When true, exclusion rules can veto candidate mutes (e.g., a logger call inside a guard block)."
        },
        "mutedBoilerplate.categories.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Mute telemetry calls (Application Insights, Activity, Metrics)."
        },
        "mutedBoilerplate.categories.logging.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Mute logging calls (ILogger, Serilog, Console, Trace)."
        },
        "mutedBoilerplate.categories.signature.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Mute method signatures. Off by default — the built-in rule mutes every signature, which is too aggressive for most code. Toggle with Ctrl+Alt+M, S."
        },
        "mutedBoilerplate.categories.guards.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Mute parameter guard expressions."
        },
        "mutedBoilerplate.autoCollapse": {
          "type": "boolean",
          "default": true,
          "description": "Auto-collapse muted regions whose category has autoCollapse=true in the ruleset."
        },
        "mutedBoilerplate.debounceMs": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 2000,
          "description": "Debounce window (ms) between document edits and decoration refresh."
        },
        "mutedBoilerplate.sidecarPath": {
          "type": "string",
          "default": "",
          "description": "Override path to the .NET sidecar executable. Empty = use the bundled binary for this platform."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js --production",
    "watch": "node esbuild.config.js --watch",
    "compile": "tsc -p ."
  },
  "dependencies": {
    "vscode-jsonrpc": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.9.3"
  }
}
